*.py[cod]
*$py.class
*.pyo

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# pytest
.pytest_cache/
.coverage
htmlcov/
*.cover

# mypy
.mypy_cache/
.dmypy.json

